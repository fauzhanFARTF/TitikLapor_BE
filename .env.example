# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_ENV=development
SECRET_KEY=ganti-dengan-string-acak-panjang
HOSTS=localhost,127.0.0.1

# ── Database (Supabase Session Pooler / Postgres+PostGIS lokal) ──────────────
DB_NAME=titiklapor
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer

# ── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ── Header keamanan ──────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=True
CSP_REPORT_ONLY=False
CSP_EXTRA_IMG_SRC=
CSP_EXTRA_CONNECT_SRC=

# ── GeoDjango (macOS/Homebrew saja) ──────────────────────────────────────────
# GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib

# ── Routing ──────────────────────────────────────────────────────────────────
ROUTING_ENGINE=naive
OSRM_BASE_URL=https://router.project-osrm.org

# ── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=

# ── Supabase Storage (opsional, wajib di HF Spaces) ─────────────────────────
USE_SUPABASE_STORAGE=False
SUPABASE_STORAGE_BUCKET=titiklapor-media
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_PUBLIC_HOST=
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
